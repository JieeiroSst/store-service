APP_ENV=development
APP_PORT=8080
APP_NAME=referral-service
APP_VERSION=1.0.0

AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY

DYNAMODB_ENDPOINT=http://localhost:8000

TABLE_REFERRAL_LINKS=referral_links
TABLE_REFERRAL_EVENTS=referral_events
TABLE_REFERRAL_REWARDS=referral_rewards
TABLE_USER_STATS=user_referral_stats

DEEP_LINK_BASE_URL=https://app.example.com/invite
APP_STORE_URL=https://apps.apple.com/app/id123456789
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.example.app

REFERRAL_TTL_DAYS=30
MAX_REFERRAL_PER_DAY=50


LOG_LEVEL=debug

LOG_FILE_PATH=

LOG_MAX_SIZE_MB=100
LOG_MAX_BACKUPS=7
LOG_MAX_AGE_DAYS=30
